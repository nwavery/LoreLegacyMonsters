  dialogId: dlg_mentor_story
  entries:
  - speaker: Cael, Veteran Mentor
    line: A party that wins one burst fight still dies on the ridge. I need to see endurance, not bravado.
    choiceNextIds: []
  - speaker: Cael, Veteran Mentor
    line: Win two real fights out here, then climb for the spire. Varo only respects trainers who arrive prepared.
    choiceNextIds: []
