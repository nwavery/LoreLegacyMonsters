  dialogId: dlg_storm_boss_story
  entries:
  - speaker: Varo, Storm Tyrant
    line: The delta drowns, the ridge bows, and still they send one more challenger up my stairs.
    choiceNextIds: []
  - speaker: Varo, Storm Tyrant
    line: If Hollowfen wants the storm to kneel, let its chosen trainer prove they can seize it from me.
    choiceNextIds: []
